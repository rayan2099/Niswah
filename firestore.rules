rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - id: string (required)
    //   - email_hash: string
    //   - display_name: string
    //   - birth_year: number
    //   - madhhab: string (required, enum)
    //   - language: string (required, enum)
    //   - avg_cycle_length: number
    //   - avg_haid_duration: number
    //   - goal_flags: list
    //   - conditions: list
    //   - notification_prefs: map
    //   - anonymous_mode: bool
    //   - premium_status: bool
    //   - adah_confidence: number
    //   - prayer_calculation_method: string
    //   - location_lat: number
    //   - location_lng: number
    //   - created_at: string (ISO 8601)
    //   - updated_at: string (ISO 8601)
    //   - role: string (enum: 'user', 'admin')
    //
    // Collection: /users/{userId}/cycle_entries/{entryId}
    // Document ID: entryId
    // Fields:
    //   - id: string
    //   - user_id: string (required)
    //   - date: string (required, ISO 8601 date)
    //   - time_logged: string (ISO 8601 date-time)
    //   - fiqh_state: string (required, enum)
    //   - flow_intensity: string
    //   - blood_color: string
    //   - blood_thickness: string
    //   - kursuf_used: bool
    //   - discharge_internal: bool
    //   - is_predicted: bool
    //   - prediction_confidence: number
    //   - is_dirty: bool
    //   - created_at: string (ISO 8601)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['madhhab', 'language']) &&
             data.madhhab in ['HANAFI', 'SHAFII', 'MALIKI', 'HANBALI'] &&
             data.language in ['en', 'ar'];
    }

    function isValidCycleEntry(data) {
      return data.keys().hasAll(['user_id', 'date', 'fiqh_state']) &&
             data.fiqh_state in ['HAID', 'TUHR', 'ISTIHADAH', 'NIFAS'] &&
             data.user_id == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
      
      allow delete: if isAdmin();
      
      match /cycle_entries/{entryId} {
        allow read, delete: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidCycleEntry(request.resource.data);
      }

      match /symptoms_log/{logId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /prayer_log/{logId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /adah_ledger/{ledgerId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /nifas_records/{recordId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /ramadan_records/{recordId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /secret_vault/{entryId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /community_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.author_id == request.auth.uid &&
                    request.resource.data.content.size() < 5000;
      allow update: if isAuthenticated() && 
                    (resource.data.author_id == request.auth.uid || isAdmin()) &&
                    request.resource.data.author_id == resource.data.author_id;
      allow delete: if isAuthenticated() && (resource.data.author_id == request.auth.uid || isAdmin());
    }

  }
}
